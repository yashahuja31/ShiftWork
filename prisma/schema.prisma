// Prisma schema for Shiftwork.
//
// Local dev uses SQLite (no server to install). To move to Postgres for
// production, change `provider` below to "postgresql" and point
// DATABASE_URL at your instance — no other code changes are required
// because every query in this app goes through Prisma's query builder
// (never raw SQL), so there is nothing engine-specific to rewrite.

generator client {
  provider      = "prisma-client-js"
  // "native" (the default) matches whatever OS runs `prisma generate`,
  // which is correct when Vercel builds and runs your app on the same
  // infrastructure — the common case for a standard Next.js deploy. Listed
  // explicitly anyway so it keeps working if you ever build somewhere else
  // (Docker, a different CI) and deploy to Vercel's Lambda runtime, which
  // needs the rhel-openssl-3.0.x target specifically.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  // provider = "postgresql" // <- flip this for production
  url      = env("DATABASE_URL")
}

// Mirrors the Clerk user. We never store passwords, tokens, or session data
// ourselves — Clerk owns all of that. This table exists only so simulation
// runs can be linked to a stable local id via a foreign key.
model User {
  id        String   @id // Clerk user id (e.g. "user_2abc..."), never client-generated
  email     String   @unique
  createdAt DateTime @default(now())

  runs SimulationRun[]
}

// One completed (or in-progress-and-abandoned) playthrough.
// `decisions` stores the ordered list of choice ids the player made (as a
// JSON-stringified array, not Prisma's `Json` type — SQLite's connector
// doesn't support `Json` at all, and validating the schema against it fails
// with P1012. A plain String column that the app JSON.stringify()s on write
// and JSON.parse()s on read works identically across SQLite, Postgres, and
// MySQL, so there's nothing to change here even when you flip the
// datasource provider for production. See src/app/api/simulation/route.ts.
model SimulationRun {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  career        String   @default("trauma_surgeon")
  difficulty    String   @default("normal")
  endingKey     String
  finalStress   Int
  finalEnergy   Int
  finalRep      Int
  finalMoney    Int
  highlights    Int // generic "career milestone" counter; label shown in UI comes from each career's own JSON (highlightLabel)
  decisions     String // JSON.stringify(string[]) -- see comment above
  createdAt     DateTime @default(now())

  @@index([userId])
}
