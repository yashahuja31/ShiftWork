# ──────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` — it is already in .gitignore.
# ──────────────────────────────────────────────────────────────────────────

# --- Database -----------------------------------------------------------
# Local dev default (SQLite, zero setup, file lives at prisma/dev.db):
DATABASE_URL="file:./dev.db"
# Production (Postgres) example — use a least-privilege DB user, not a superuser:
# DATABASE_URL="postgresql://shiftwork_app:CHANGE_ME@localhost:5432/shiftwork?schema=public&sslmode=require"

# --- Auth (Clerk) ---------------------------------------------------------
# Get these from https://dashboard.clerk.com after creating an application.
# The publishable key is safe for the browser; the secret key is server-only
# and must never be exposed to the client or committed to git.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- Optional AI narration ------------------------------------------------
# The simulation runs fully offline without these. If set, one special scene
# ("the complication") is narrated dynamically instead of using the static
# fallback text. Server-side only — never referenced from client code.
# OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# GEMINI_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- App -------------------------------------------------------------------
NODE_ENV="development"
